# Copy this file to .env.local (recommended) or .env.development for local work.
# Do not commit files containing real values.

# EmailJS (contact form) — public keys; restrict domains in the EmailJS dashboard
NEXT_PUBLIC_EMAILJS_USER_ID=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# Google Analytics
NEXT_PUBLIC_GA_TRACKING=

# Optional: Vercel project env names mapped in next.config.mjs
# NEXT_PUBLIC_VERCEL_ENV_EMAILJS_USER_ID=
# NEXT_PUBLIC_VERCEL_ENV_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_VERCEL_ENV_EMAILJS_TEMPLATE_ID=
